[gd_resource type="Resource" script_class="CampaignDefinition" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/campaign_definition.gd" id="1"]

[resource]
script = ExtResource("1")
id = "prologue_first_half"
campaign_name = "序章前半:森林獵人父子"
is_prologue = true
starting_deck = {
"tool_arrow_pierce": 10,
"tool_stone_impact": 8,
"intel_weakness": 2
}
chain_ids = Array[String](["chain_1", "chain_2", "chain_3", "chain_4", "chain_5"])
prologue_narrative = "山林邊緣,晨霧未散。父親帶著兒子第一次進入真正的狩獵場。「今天,你來決定每一箭。」"
ending_narrative = "父親拿起異變巨狼的斷臂,沉思良久。「這事我得獨自去查。你回家等我——或者,如果你準備好了,就來找我。」"
